{
  "realm": "idp",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "roles": {
    "realm": [
      { "name": "platform-user", "description": "Базовый пользователь портала IDP" },
      { "name": "platform-admin", "description": "Администратор платформы IDP" }
    ]
  },
  "clients": [
    {
      "clientId": "idp-portal",
      "name": "IDP Developer Portal",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "idp-portal-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:4180/oauth2/callback"],
      "webOrigins": ["http://localhost:4180"]
    },
    {
      "clientId": "idm-service-account",
      "name": "IDM Service Account (каталог субъектов)",
      "description": "Сервис-аккаунт IDM для ЧТЕНИЯ каталога пользователей realm (ADR-0016): поиск/резолв через Keycloak Admin REST. Доступ ограничен realm-management ролями view-users/query-users.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "idm-service-account-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true
    }
  ],
  "users": [
    {
      "id": "11111111-1111-1111-1111-111111111111",
      "username": "dev",
      "enabled": true,
      "email": "dev@example.com",
      "emailVerified": true,
      "firstName": "Dev",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "dev", "temporary": false }
      ],
      "realmRoles": ["platform-user", "platform-admin"]
    },
    {
      "id": "22222222-2222-2222-2222-222222222222",
      "username": "alice",
      "enabled": true,
      "email": "alice@example.com",
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Ivanova",
      "credentials": [
        { "type": "password", "value": "alice", "temporary": false }
      ],
      "realmRoles": ["platform-user"]
    },
    {
      "id": "33333333-3333-3333-3333-333333333333",
      "username": "bob",
      "enabled": true,
      "email": "bob@example.com",
      "emailVerified": true,
      "firstName": "Bob",
      "lastName": "Petrov",
      "credentials": [
        { "type": "password", "value": "bob", "temporary": false }
      ],
      "realmRoles": ["platform-user"]
    },
    {
      "username": "service-account-idm-service-account",
      "enabled": true,
      "serviceAccountClientId": "idm-service-account",
      "clientRoles": {
        "realm-management": ["view-users", "query-users"]
      }
    }
  ]
}
