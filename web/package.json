{
  "name": "@idp/web",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Портал IDP: SPA сценария «Создание сервиса» (список/форма/прогресс) и кодоген TS-клиента и zod-схем из OpenAPI периметра.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "gen:types": "openapi-typescript ../openapi/openapi.yaml -o src/api/schema.ts",
    "gen:zod": "openapi-zod-client ../openapi/openapi.yaml -o src/api/client.ts --export-schemas",
    "gen:spec": "node -e \"require('fs').copyFileSync('../openapi/openapi.yaml','public/openapi.yaml')\"",
    "gen": "npm run gen:types && npm run gen:zod && npm run gen:spec",
    "gen:check": "npm run gen && git diff --exit-code src/api public/openapi.yaml",
    "lint:openapi": "spectral lint ../openapi/openapi.yaml --ruleset ../.spectral.yaml --fail-severity=error"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "6.16.0",
    "@tailwindcss/vite": "4.3.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.3.4",
    "jsdom": "29.1.1",
    "openapi-typescript": "7.13.0",
    "openapi-zod-client": "1.18.3",
    "tailwindcss": "4.3.1",
    "typescript": "5.9.3",
    "vite": "6.0.7",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "@fontsource-variable/geist": "5.2.9",
    "@hookform/resolvers": "5.4.0",
    "@tanstack/react-query": "5.101.1",
    "@zodios/core": "10.9.6",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.79.0",
    "react-router-dom": "7.18.0",
    "tailwind-merge": "3.6.0",
    "zod": "3.25.76"
  }
}
