{
  "name": "@idp/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Каркас портала IDP: кодоген TS-клиента и zod-схем из OpenAPI периметра.",
  "scripts": {
    "gen:types": "openapi-typescript ../openapi/openapi.yaml -o src/api/schema.ts",
    "gen:zod": "openapi-zod-client ../openapi/openapi.yaml -o src/api/client.ts --export-schemas",
    "gen": "npm run gen:types && npm run gen:zod",
    "gen:check": "npm run gen && git diff --exit-code src/api"
  },
  "devDependencies": {
    "openapi-typescript": "7.5.0",
    "openapi-zod-client": "1.18.2",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@tanstack/react-query": "5.59.0",
    "@zodios/core": "10.9.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "7.53.0",
    "zod": "3.23.8"
  }
}
