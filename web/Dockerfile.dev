# Dev-образ портала IDP для локального стенда (docker-compose): Vite dev-сервер с
# HMR и прокси /api на gateway. Production-образ — в web/Dockerfile (multi-stage
# vite build → nginx, для Kubernetes-деплоя, ADR-0024).
FROM node:22-alpine
WORKDIR /app

# Сначала манифесты — для кэширования слоя зависимостей.
COPY package.json package-lock.json ./
RUN npm ci

# Затем исходники портала (сгенерированный из OpenAPI клиент уже в src/api).
COPY . ./

EXPOSE 3000
# --host 0.0.0.0 — чтобы dev-сервер был доступен снаружи контейнера.
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
